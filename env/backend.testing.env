NODE_ENV=testing
PORT=5001

REDIS_ENABLED=true
REDIS_REQUIRED=false
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_KEY_PREFIX=testing:pw-backend:
REDIS_DEFAULT_TTL_SECONDS=300

FRONTEND_URL=http://testing.jipanditji.com
BACKEND_URL=https://testing.backend.jipanditji.com

CDN_UPLOAD_URL=https://cdn.backend.jipanditji.com/protected
CDN_PUBLIC_URL=https://cdn.backend.jipanditji.com

CRON_ENABLED=false
CRON_SINGLE_MACHINE_LOCK=true
CRON_TIMEZONE=Asia/Kolkata
PAYMENT_EXPIRY_CRON_ENABLED=false
PAYMENT_EXPIRY_CRON=*/5 * * * *
