NODE_ENV=production
PORT=5001

DATABASE_DIALECT=mysql
DATABASE_HOST=replace-with-production-db-host
DATABASE_NAME=replace-with-production-db-name
DATABASE_USERNAME=replace-with-production-db-user
DATABASE_PASSWORD=replace-with-production-db-password

REDIS_ENABLED=true
REDIS_REQUIRED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

FRONTEND_URL=http://app.jipanditji.com
BACKEND_URL=http://backend.jipanditji.com
SECRET_KEY=replace-with-production-secret
JWT_SECRET=replace-with-production-jwt-secret

CRON_ENABLED=true
CRON_SINGLE_MACHINE_LOCK=true
CRON_TIMEZONE=Asia/Kolkata
PAYMENT_EXPIRY_CRON_ENABLED=true
PAYMENT_EXPIRY_CRON=*/5 * * * *

OPENAI_API_KEY=
GOOGLE_CLIENT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=

CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

AWS_REGION=ap-south-1
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=

CDN_UPLOAD_URL=https://cdn.backend.jipanditji.com/protected
CDN_PUBLIC_URL=https://cdn.backend.jipanditji.com
WEBDAV_USER=
WEBDAV_PASS=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
OTP_EXPIRY_SECONDS=300
